# ai-security-guardrails — Environment Configuration
# =========================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# AI Provider configuration
# ---------------------------------------------------------------------------
AI_PROVIDER=openai  # openai, azure_openai

# OpenAI
OPENAI_API_KEY=your_key_here

# Azure OpenAI (only needed when AI_PROVIDER=azure_openai)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# ---------------------------------------------------------------------------
# Security configuration
# ---------------------------------------------------------------------------
POLICY_MODE=enforce  # enforce, warn, audit_only
MAX_INPUT_TOKENS=2000
MAX_OUTPUT_TOKENS=4000
REDACT_LOGS=true          # Strip sensitive fields from log output
AUDIT_ENABLED=true        # Write structured audit events to the audit log
TOOL_APPROVAL_REQUIRED=true   # Block all agent tool calls unless explicitly allowed in policy
TENANT_ISOLATION=false    # Enable per-tenant policy evaluation (multi-tenant apps)

# ---------------------------------------------------------------------------
# Input controls
# ---------------------------------------------------------------------------
INPUT_MAX_LENGTH=10000          # Hard character limit on user inputs
INPUT_RISK_THRESHOLD=0.7        # Score >= this triggers review/block

# ---------------------------------------------------------------------------
# Output controls
# ---------------------------------------------------------------------------
OUTPUT_RISK_THRESHOLD=0.8       # Score >= this triggers output review
REDACT_PII=true                 # Automatically redact PII from model outputs
